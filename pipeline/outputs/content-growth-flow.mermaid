flowchart LR
    subgraph INPUT["📥 INPUT"]
        Context["Context"]
        KB["Knowledge Base"]
    end

    subgraph WORK["⚙️ WORK"]
        Opportunities["Opportunities"]
        Execution["Execution"]
    end

    subgraph HIL["👤 HUMAN IN LOOP"]
        FailureMode["Failure Mode"]
        Calibrating["Calibrating"]
        Polishing["Polishing"]
    end

    subgraph OUTPUT["📄 OUTPUT"]
        Pages["Pages"]
        Create["Create"]
        Update["Update"]
        Delete["Delete"]
    end

    subgraph DESTINATION["🌐 DESTINATION"]
        Website["Website"]
        Code["Code"]
        ContentAssets["Content & Assets"]
        KnowledgeGraph["Knowledge Graph / Brand"]
    end

    subgraph OUTCOME["📈 OUTCOME"]
        OrganicGrowth["Organic Growth<br/>(Compounding)"]
    end

    subgraph METRICS["📊 METRICS"]
        Conversion["Conversion"]
        Traffic["Traffic / Engagement"]
        Visibility["Visibility"]
    end

    subgraph TARGET["🎯 TARGET AUDIENCE"]
        Buyer["Buyer"]
        Agents["Agents"]
        Training["Training"]
    end

    %% Flow connections
    INPUT --> WORK
    WORK --> OUTPUT
    HIL -.-> OUTPUT
    OUTPUT --> DESTINATION
    DESTINATION --> OUTCOME
    OUTCOME --> METRICS
    METRICS --> TARGET

    %% Internal connections
    Pages --> Create
    Pages --> Update
    Pages --> Delete
    Website --> Code
    Website --> ContentAssets
    ContentAssets --> KnowledgeGraph

    %% Feedback loop
    TARGET -.->|"Why?"| KnowledgeGraph
